---
import Button from "@components/ui/Button.astro";
import SectionLabel from "@components/ui/SectionLabel.astro";

const faqs = [
  {
    question: "Dans quelles communes intervenez-vous ?",
    answer:
      "Nous intervenons à Bruxelles et dans toute la périphérie : Uccle, Ixelles, Waterloo, Braine-l'Alleud, Wavre, Ottignies, Louvain-la-Neuve, Nivelles, Tervuren, Overijse et environs. Vous ne trouvez pas votre commune ? Contactez-nous, nous étudions toute demande.",
  },
  {
    question: "Combien coûte un nettoyage à Bruxelles ?",
    answer:
      "Le prix dépend du type de prestation, de la superficie et de la fréquence. Nous proposons des devis gratuits et personnalisés — contactez-nous pour recevoir une estimation en moins de 2 heures. Les contrats réguliers bénéficient de tarifs préférentiels.",
  },
  {
    question: "Intervenez-vous pour des particuliers et des professionnels ?",
    answer:
      "Oui, nous travaillons aussi bien pour des particuliers que pour des professionnels (gérants d'immeubles, agences immobilières, entreprises). Nos prestations s'adaptent à chaque contexte : intervention ponctuelle ou contrat d'entretien régulier.",
  },
  {
    question: "Faut-il être présent lors de l'intervention ?",
    answer:
      "Non, votre présence n'est pas obligatoire. Beaucoup de nos clients nous confient un accès (clé, code, digicode). Nos équipes sont assurées et formées pour intervenir en toute discrétion et sécurité.",
  },
  {
    question: "Les agents sont-ils vérifiés et assurés ?",
    answer:
      "Oui. Chaque agent fait l'objet d'une vérification des antécédents, d'un entretien et d'une sélection rigoureuse. Nos équipes sont entièrement assurées pour intervenir chez vous en toute sécurité.",
  },
  {
    question: "Utilisez-vous des produits écologiques ?",
    answer:
      "Oui — nous privilégions des produits certifiés éco-responsables, non toxiques et sans danger pour les enfants et les animaux de compagnie. Sur demande, nous adaptons les produits selon vos préférences ou allergies.",
  },
];
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  })}
/>

<section id="faq" class="w-full">
  <div class="rounded-3xl bg-(--color-surface-secondary) px-6 py-16 md:px-12 md:py-24">
    <!-- Headline -->
    <div class="mx-auto mb-16 flex max-w-2xl flex-col items-center gap-4 text-center">
      <SectionLabel text="FAQ" />
      <h2
        data-reveal="words"
        class="font-display text-5xl leading-[0.8] font-bold tracking-tight uppercase lg:text-[88px]"
      >
        Réponses à vos questions
      </h2>
      <p class="max-w-sm text-2xl leading-none font-semibold tracking-tight opacity-70">
        Tout ce que vous devez savoir avant de réserver votre premier nettoyage.
      </p>
    </div>

    <!-- FAQ items -->
    <div data-reveal="cards" class="mx-auto flex max-w-2xl flex-col gap-3">
      {
        faqs.map((faq) => (
          <div class="faq-item rounded-xl bg-white px-6 py-5">
            <button
              class="faq-trigger flex w-full items-center justify-between gap-6 text-left"
              aria-expanded="false"
            >
              <span class="text-lg leading-snug font-semibold md:text-2xl">{faq.question}</span>
              <span class="relative flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-(--color-accent)">
                <span class="absolute h-0.5 w-3 rounded-full bg-(--color-text-primary)" />
                <span class="faq-v-bar absolute h-3 w-0.5 rounded-full bg-(--color-text-primary) transition-transform duration-300" />
              </span>
            </button>
            <div class="faq-body grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
              <div class="overflow-hidden">
                <p class="m-0 pt-5 text-lg leading-relaxed font-medium opacity-60">{faq.answer}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-16 flex justify-center">
      <Button
        size="lg"
        href="tel:+32486518181"
        data-umami-event="phone_click"
        data-umami-event-location="faq"
        data-umami-event-channel="phone"
        class="hover:bg-(--color-text-primary) hover:text-(--color-background) [&_svg]:text-(--color-background)"
      >
        Poser nous vos questions
      </Button>
    </div>
  </div>
</section>

<style>
  .faq-item.is-open .faq-body {
    grid-template-rows: 1fr;
  }
  .faq-item.is-open .faq-v-bar {
    transform: rotate(90deg);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".faq-item").forEach((item) => {
    item.querySelector(".faq-trigger")?.addEventListener("click", () => {
      const isOpen = item.classList.contains("is-open");

      // Close all
      document.querySelectorAll(".faq-item").forEach((other) => {
        other.classList.remove("is-open");
        other.querySelector(".faq-trigger")?.setAttribute("aria-expanded", "false");
      });

      if (!isOpen) {
        item.classList.add("is-open");
        item.querySelector(".faq-trigger")?.setAttribute("aria-expanded", "true");
      }
    });
  });
</script>
