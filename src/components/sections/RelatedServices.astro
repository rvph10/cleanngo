---
import { Image } from "astro:assets";
import type { Service } from "@/data/services";

interface Props {
  relatedServices: Service[];
}

const { relatedServices } = Astro.props;
---

<section class="mx-auto w-full max-w-7xl px-4 py-12 md:px-8">
  <h2 data-reveal="words" class="font-display mb-8 text-2xl font-bold md:text-4xl">
    Vous pourriez aussi avoir besoin de
  </h2>
  <div data-reveal="cards" class="grid grid-cols-2 gap-4 md:grid-cols-3">
    {
      relatedServices.map((service) => (
        <a
          href={service.href}
          class="rounded-2xl bg-(--color-surface-secondary) p-4 opacity-100 transition hover:opacity-80"
        >
          <Image
            src={service.image}
            alt={service.name}
            width={600}
            height={400}
            class="h-56 w-full rounded-xl object-cover object-top"
          />
          <p class="font-display mt-3 text-xl font-bold text-(--color-text-primary)">
            {service.name}
          </p>
        </a>
      ))
    }
  </div>
</section>
