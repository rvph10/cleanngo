---
const areas = [
  "Bruxelles",
  "Uccle",
  "Ixelles",
  "Etterbeek",
  "Forest",
  "Anderlecht",
  "Molenbeek",
  "Schaerbeek",
  "Waterloo",
  "Uccle",
  "Braine-l'Alleud",
  "Lasne",
  "Wavre",
  "Ottignies",
  "Louvain-la-Neuve",
  "Nivelles",
  "Genappe",
  "Overijse",
  "Tervuren",
  "Rixensart",
];

// deduplicate (Uccle appears twice in source intentionally only once)
const uniqueAreas = [...new Set(areas)];
---

<section class="w-full py-16 md:py-20">
  <div class="flex flex-col items-center gap-8 text-center">
    <p class="font-display text-xs font-bold tracking-[0.25em] text-(--color-text-primary)/40 uppercase">
      Zones d'intervention
    </p>
    <h2
      data-reveal="words"
      class="font-display max-w-2xl text-4xl leading-[0.9] font-bold uppercase md:text-5xl"
    >
      Bruxelles et toute la périphérie
    </h2>
    <p data-reveal="fade" class="max-w-lg text-lg text-(--color-text-primary)/60">
      Nous intervenons à Bruxelles et dans les communes environnantes du Brabant Wallon et Brabant Flamand.
    </p>

    <ul
      data-reveal="cards"
      class="flex flex-wrap justify-center gap-3 max-w-3xl"
      aria-label="Communes desservies"
    >
      {
        uniqueAreas.map((area) => (
          <li class="rounded-full border border-(--color-text-primary)/15 bg-(--color-surface-secondary) px-4 py-2 text-sm font-semibold text-(--color-text-primary)/70">
            {area}
          </li>
        ))
      }
    </ul>

    <p data-reveal="fade" class="text-sm text-(--color-text-primary)/40">
      Votre commune n'est pas listée ?{" "}
      <a href="/contact" class="underline underline-offset-2 hover:text-(--color-text-primary) transition-colors">
        Contactez-nous
      </a>
      , nous étudions toute demande.
    </p>
  </div>
</section>
