---
import SectionLabel from "@components/ui/SectionLabel.astro";

const areas = [
  "Bruxelles",
  "Ixelles",
  "Etterbeek",
  "Woluwe-Saint-Lambert",
  "Woluwe-Saint-Pierre",
  "Auderghem",
  "Watermael-Boitsfort",
  "Schaerbeek",
  "Evere",
  "Saint-Gilles",
  "Forest",
  "Uccle",
  "Anderlecht",
  "Molenbeek",
  "Laeken",
  "Jette",
  "Koekelberg",
  "Berchem-Sainte-Agathe",
  "Kraainem",
  "Wezembeek-Oppem",
  "Tervuren",
  "Zaventem",
  "Overijse",
  "Rhode-Saint-Genèse",
  "Rixensart",
  "Waterloo",
  "Braine-l'Alleud",
  "Lasne",
  "Wavre",
  "Ottignies",
  "Louvain-la-Neuve",
  "Genappe",
];
---

<section class="w-full" aria-label="Zones d'intervention CleanNgo">
  <!-- Card: heading + towns -->
  <div data-area-card class="rounded-3xl bg-(--color-surface-secondary) p-8 lg:p-10">
    <div class="mb-8 flex flex-col gap-4">
      <SectionLabel text="Zones d'intervention" />
      <h2
        data-area-heading
        class="font-display m-0 text-5xl leading-[0.9] font-bold uppercase lg:text-6xl"
      >
        Bruxelles &amp; toute la périphérie
      </h2>
    </div>

    <ul class="flex flex-wrap gap-2" aria-label="Communes desservies">
      {
        areas.map((area) => (
          <li
            data-area-pill
            class="rounded-full bg-(--color-background) px-4 py-2 text-sm font-semibold text-(--color-text-primary)/70"
          >
            {area}
          </li>
        ))
      }
    </ul>
  </div>
  <!-- Hidden SEO node -->
  <ul class="sr-only" aria-hidden="true">
    {areas.map((area) => <li>Nettoyage à {area}</li>)}
  </ul>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    // Heading slides up
    const heading = document.querySelector<HTMLElement>("[data-area-heading]");
    if (heading) {
      gsap.set(heading, { y: 28, opacity: 0 });
      ScrollTrigger.create({
        trigger: heading,
        start: "top 92%",
        once: true,
        onEnter: () => gsap.to(heading, { y: 0, opacity: 1, duration: 0.7, ease: "power3.out" }),
      });
    }

    // Card wipes in
    const card = document.querySelector<HTMLElement>("[data-area-card]");
    if (card) {
      gsap.set(card, { clipPath: "inset(100% 0 0 0 round 1.5rem)" });
      ScrollTrigger.create({
        trigger: card,
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(card, {
            clipPath: "inset(0% 0 0 0 round 1.5rem)",
            duration: 0.9,
            ease: "expo.out",
          }),
      });
    }

    // Pills pop in with unsynchronized delays
    document.querySelectorAll<HTMLElement>("[data-area-pill]").forEach((pill, i) => {
      const delay = (i % 5) * 0.045 + Math.floor(i / 5) * 0.02;
      gsap.set(pill, { scale: 0.82, opacity: 0 });
      ScrollTrigger.create({
        trigger: pill,
        start: "top 97%",
        once: true,
        onEnter: () =>
          gsap.to(pill, { scale: 1, opacity: 1, duration: 0.38, delay, ease: "back.out(1.8)" }),
      });
    });

    // Footer note fades in
    const note = document.querySelector<HTMLElement>("[data-area-note]");
    if (note) {
      gsap.set(note, { y: 12, opacity: 0 });
      ScrollTrigger.create({
        trigger: note,
        start: "top 98%",
        once: true,
        onEnter: () => gsap.to(note, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" }),
      });
    }
  }
</script>
