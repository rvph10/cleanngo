---
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import SectionLabel from "@components/ui/SectionLabel.astro";
import { staticImageAssets } from "@/data/images";
---

<section id="equipe" class="w-full">
  <div
    class="flex flex-col gap-4 overflow-hidden rounded-3xl md:relative md:h-220 md:max-h-[90vh] md:flex-row md:items-end md:gap-0 md:p-6"
  >
    <!-- Background image -->
    <div
      data-team-image
      class="relative h-80 shrink-0 overflow-hidden rounded-3xl md:absolute md:inset-0 md:h-auto md:rounded-3xl"
    >
      <Image
        src={staticImageAssets.teamPhoto}
        widths={[400, 800, 1200]}
        sizes="(max-width: 767px) 100vw, 70vw"
        loading="lazy"
        alt="Résultat de l'équipe de nettoyage sur un projet"
        class="h-full w-full object-cover"
      />
    </div>

    <!-- Content card -->
    <div
      data-team-card
      class="relative z-10 flex flex-col gap-8 rounded-2xl bg-(--color-accent) p-8 md:max-w-[42%] lg:p-12"
    >
      <SectionLabel text="Notre équipe" />

      <h2 class="text-xl font-bold tracking-tight text-(--color-text-primary) lg:text-4xl">
        Notre équipe de professionnels est prête à transformer votre espace en un havre de propreté
        et de fraîcheur.
      </h2>

      <div>
        <Button
          href="/contact"
          size="lg"
          data-umami-event="cta_click"
          data-umami-event-location="team_cta"
          class="bg-(--color-background)"
        >
          Travailler avec nous
        </Button>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const image = document.querySelector<HTMLElement>("[data-team-image]");
    const card = document.querySelector<HTMLElement>("[data-team-card]");

    if (image) {
      // Wipe from right to left — reveals as if sliding open a curtain
      gsap.set(image, { clipPath: "inset(0 100% 0 0)" });
      ScrollTrigger.create({
        trigger: image,
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(image, { clipPath: "inset(0 0% 0 0)", duration: 1.1, ease: "expo.out" }),
      });
    }

    if (card) {
      gsap.set(card, { y: 36, opacity: 0 });
      ScrollTrigger.create({
        trigger: card,
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(card, { y: 0, opacity: 1, duration: 0.7, delay: 0.2, ease: "power3.out" }),
      });
    }
  }
</script>
