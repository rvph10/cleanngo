---
// Drop this section into any page.
// The form POSTs to /api/contact which uses Resend to send an email.
---

<section id="contact" class="py-(--section-padding-y)">
  <div class="mx-auto max-w-2xl px-6">
    <h2 class="font-display text-3xl font-bold lg:text-5xl">Get in touch</h2>
    <p class="mt-4 text-(--color-text-primary)">
      Tell us about your project and we'll get back to you within 24 hours.
    </p>

    <form id="contact-form" class="mt-10 grid gap-6" novalidate>
      <div class="grid gap-6 sm:grid-cols-2">
        <div>
          <label for="name" class="mb-2 block text-sm font-medium">Name *</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3 transition focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent) focus:outline-none"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-sm font-medium">Email *</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3 transition focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent) focus:outline-none"
          />
        </div>
      </div>

      <div>
        <label for="company" class="mb-2 block text-sm font-medium">Company</label>
        <input
          id="company"
          name="company"
          type="text"
          autocomplete="organization"
          class="w-full rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3 transition focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent) focus:outline-none"
        />
      </div>

      <div>
        <label for="budget" class="mb-2 block text-sm font-medium">Budget</label>
        <select
          id="budget"
          name="budget"
          class="w-full rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3 transition focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent) focus:outline-none"
        >
          <option value="">Select a range…</option>
          <option value="small">Less than €5k</option>
          <option value="medium">€5k – €20k</option>
          <option value="large">€20k – €50k</option>
          <option value="enterprise">€50k+</option>
        </select>
      </div>

      <div>
        <label for="message" class="mb-2 block text-sm font-medium">Message *</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full resize-none rounded-md border border-(--color-border) bg-(--color-surface) px-4 py-3 transition focus:border-(--color-accent) focus:ring-2 focus:ring-(--color-accent) focus:outline-none"
        ></textarea>
      </div>

      <div id="form-status" class="hidden rounded-md p-4 text-sm" role="status" aria-live="polite">
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="inline-flex items-center gap-2 self-start rounded-lg bg-(--color-accent) px-6 py-3 font-semibold text-(--color-text-primary) transition-shadow transition-transform hover:-translate-y-0.5 hover:shadow-[0_0_0_2px_var(--color-text-primary)] disabled:pointer-events-none disabled:opacity-50"
      >
        Send message
      </button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById("form-status")!;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const getValue = (name: string) =>
      (form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement)
        ?.value ?? "";

    const payload = {
      name: getValue("name"),
      email: getValue("email"),
      company: getValue("company") || undefined,
      budget: getValue("budget") || undefined,
      message: getValue("message"),
    };

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    type UmamiWindow = Window & {
      umami?: { track(name: string, data?: Record<string, string>): void };
    };
    const umamiTrack = (name: string, data?: Record<string, string>) =>
      (window as UmamiWindow).umami?.track(name, data);

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      const json = (await res.json()) as { success: boolean; message: string };

      statusEl.classList.remove("hidden");

      if (res.ok) {
        statusEl.className =
          "rounded-md border border-(--color-border) bg-(--color-surface-secondary) p-4 text-sm text-(--color-text-primary)";
        statusEl.textContent = json.message;
        umamiTrack("contact_form_submit", { budget: getValue("budget") || "not_specified" });
        form.reset();
      } else {
        statusEl.className =
          "rounded-md border border-(--color-border) bg-(--color-surface-secondary) p-4 text-sm text-(--color-text-primary)";
        statusEl.textContent = json.message;
        umamiTrack("contact_form_error", { status: String(res.status) });
      }
    } catch {
      statusEl.className =
        "rounded-md border border-(--color-border) bg-(--color-surface-secondary) p-4 text-sm text-(--color-text-primary)";
      statusEl.textContent = "Network error. Please try again.";
      umamiTrack("contact_form_error", { status: "network_error" });
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Send message";
    }
  });
</script>
