---
import Button from "@components/ui/Button.astro";
import { imageAssets } from "@/data/images";
---

<section class="w-full pt-8 lg:pt-12">
  <div class="flex flex-col gap-4 lg:grid lg:grid-cols-2" data-hero-grid>
    <div
      data-hero-left
      class="relative flex flex-col justify-between gap-12 overflow-hidden rounded-3xl bg-(--color-text-primary) p-4 text-(--color-surface) md:p-8 lg:gap-16 lg:p-12"
    >
      <div class="relative mb-8 h-56 overflow-hidden rounded-2xl lg:hidden">
        <video
          loop
          muted
          playsinline
          preload="none"
          data-hero-video
          class="absolute inset-0 h-full w-full object-cover"
          poster={imageAssets.heroPoster}
        >
          <source src={imageAssets.heroVideoWebm} type="video/webm" />
          <source src={imageAssets.heroVideoMp4} type="video/mp4" />
        </video>
      </div>

      <div class="-mt-12 flex flex-col items-start gap-8 lg:mt-0 lg:gap-10">
        <a
          data-hero-badge
          href="https://www.google.com/search?q=Clean+Ngo+Avis#lkt=LocalPoiReviews"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="4.9 sur Google — Consultez nos avis"
          data-umami-event="google_reviews_click"
          class="group flex w-fit items-center gap-3 rounded-full bg-white/10 p-1 pr-5 transition-all duration-300 hover:bg-white/15 hover:ring-1 hover:ring-white/30"
        >
          <div
            class="flex size-8 shrink-0 items-center justify-center rounded-full bg-white shadow-sm transition-transform duration-300 group-hover:scale-110 sm:size-9"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 48 48"
              xmlns="http://www.w3.org/2000/svg"
              class="sm:size-5"
            >
              <path
                fill="#EA4335"
                d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
              ></path>
              <path
                fill="#4285F4"
                d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
              ></path>
              <path
                fill="#FBBC05"
                d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24s.92 7.54 2.56 10.78l7.97-6.19z"
              ></path>
              <path
                fill="#34A853"
                d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
              ></path>
            </svg>
          </div>
          <span
            class="text-[10px] font-bold tracking-widest text-(--color-surface) uppercase sm:text-sm"
          >
            4.9 sur Google
          </span>
        </a>

        <h1
          data-hero-title
          class="font-display text-[3.5rem] leading-[0.9] font-bold uppercase sm:text-5xl lg:text-[100px]"
        >
          <span class="block">Nettoyage <br /> d'exception <br /> pour citadins</span>
          <span class="inline-flex items-end gap-3 whitespace-nowrap">
            <span>à</span>
            <span
              class="relative inline-block h-[1em] translate-y-[0.08em] overflow-hidden align-bottom"
            >
              <span class="animate-slot-machine flex flex-col text-(--color-accent)">
                <span class="h-[1.15em]">BRUXELLES</span>
                <span class="h-[1.15em]">IXELLES</span>
                <span class="h-[1.15em]">ETTERBEEK</span>
                <span class="h-[1.15em]">WOLUWE</span>
                <span class="h-[1.15em]">MOLENBEEK</span>
                <span class="h-[1.15em]">SCHAERBEEK</span>
                <span class="h-[1.15em]">ANDERLECHT</span>
                <span class="h-[1.15em]">TERVUREN</span>
                <span class="h-[1.15em]">WATERLOO</span>
                <span class="h-[1.15em]">AUDERGHEM</span>
                <span class="h-[1.15em]">ZAVENTEM</span>
                <span class="h-[1.15em]">RIXENSART</span>
                <span class="h-[1.15em]">WEZEMBEEK</span>
                <span class="h-[1.15em]">BRUXELLES</span>
              </span>
            </span>
          </span>
        </h1>
      </div>

      <div data-hero-cta class="flex w-full flex-wrap items-center gap-2">
        <Button
          size="lg"
          href="/contact"
          data-umami-event="cta_click"
          data-umami-event-location="hero"
          class="hover:bg-(--color-background) hover:text-(--color-text-primary) [&_svg]:text-(--color-text-primary)"
        >
          Réserver en 2 min
        </Button>
        <Button
          size="lg"
          href="/services"
          class="bg-(--color-background)/10 text-(--color-background) hover:bg-(--color-background) hover:text-(--color-text-primary) [&_svg]:text-(--color-text-primary)"
        >
          Découvrir nos services
        </Button>
      </div>
    </div>

    <div
      data-hero-right
      class="relative isolate hidden h-56 w-full overflow-hidden rounded-3xl sm:h-80 lg:block lg:h-full"
    >
      <video
        loop
        muted
        playsinline
        preload="none"
        data-hero-video
        class="absolute inset-0 -z-10 h-full w-full bg-center object-cover"
        poster={imageAssets.heroPoster}
      >
        <source src={imageAssets.heroVideoWebm} type="video/webm" />
        <source src={imageAssets.heroVideoMp4} type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";

  // Start hero videos after the page has fully loaded so they don't compete
  // with critical resources (fonts, CSS, LCP) during the initial render.
  function startHeroVideos() {
    document.querySelectorAll<HTMLVideoElement>("video[data-hero-video]").forEach((v) => {
      v.play().catch(() => {});
    });
  }
  if (document.readyState === "complete") {
    startHeroVideos();
  } else {
    window.addEventListener("load", startHeroVideos, { once: true });
  }

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    gsap.set("[data-hero-left]", { y: 32, opacity: 0 });
    gsap.set("[data-hero-right]", { scale: 1.025, opacity: 0 });
    gsap.set("[data-hero-badge]", { y: 10, opacity: 0 });
    gsap.set("[data-hero-title]", { y: 16, opacity: 0 });
    gsap.set("[data-hero-cta]", { y: 10, opacity: 0 });

    // Wait for fonts before animating so GSAP measures correct dimensions
    // and no font-swap reflow interrupts the entrance sequence.
    document.fonts.ready.then(() => {
      const tl = gsap.timeline();

      tl.to("[data-hero-left]", { y: 0, opacity: 1, duration: 0.65, ease: "expo.out" })
        .to("[data-hero-right]", { scale: 1, opacity: 1, duration: 0.8, ease: "expo.out" }, "<0.08")
        .to("[data-hero-badge]", { y: 0, opacity: 1, duration: 0.4, ease: "power3.out" }, "-=0.5")
        .to("[data-hero-title]", { y: 0, opacity: 1, duration: 0.5, ease: "power3.out" }, "-=0.3")
        .to("[data-hero-cta]", { y: 0, opacity: 1, duration: 0.4, ease: "power3.out" }, "-=0.3");
    });
  }
</script>

<style>
  .animate-slot-machine {
    animation: textSwap 14s infinite;
  }

  /* 14 items → step = 100/14 = 7.14% per slot, hold 5%, transition 2% */
  @keyframes textSwap {
    0%,
    5% {
      transform: translateY(0);
    }
    7%,
    12% {
      transform: translateY(-7.14%);
    }
    14%,
    19% {
      transform: translateY(-14.29%);
    }
    21%,
    26% {
      transform: translateY(-21.43%);
    }
    28%,
    33% {
      transform: translateY(-28.57%);
    }
    35%,
    40% {
      transform: translateY(-35.71%);
    }
    42%,
    47% {
      transform: translateY(-42.86%);
    }
    49%,
    54% {
      transform: translateY(-50%);
    }
    56%,
    61% {
      transform: translateY(-57.14%);
    }
    63%,
    68% {
      transform: translateY(-64.29%);
    }
    70%,
    75% {
      transform: translateY(-71.43%);
    }
    77%,
    82% {
      transform: translateY(-78.57%);
    }
    84%,
    89% {
      transform: translateY(-85.71%);
    }
    91%,
    100% {
      transform: translateY(-92.86%);
    }
  }
</style>
