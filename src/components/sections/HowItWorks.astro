---
import Button from "@components/ui/Button.astro";

const steps = [
  {
    number: "01",
    title: "Réservez en ligne",
    description: "Choisissez votre créneau en moins de 60 secondes sur notre plateforme.",
  },
  {
    number: "02",
    title: "Nettoyage expert",
    description: "Nos techniciens arrivent avec le matériel professionnel adapté à votre prestation.",
  },
  {
    number: "03",
    title: "Résultat impeccable",
    description: "Tout est nettoyé et rangé selon vos standards. Il ne vous reste qu'à profiter.",
  },
  {
    number: "04",
    title: "Tranquillité durable",
    description: "Un suivi personnalisé et un résultat garanti à chaque intervention.",
  },
];
---

<section class="w-full">
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-start lg:gap-6">
    <!-- Left: sticky headline -->
    <div data-hiw-left class="flex flex-col items-start gap-8 lg:sticky lg:top-30">
      <h2
        class="font-display m-0 text-5xl leading-tight font-bold tracking-tight text-(--color-text-primary) uppercase lg:text-6xl"
      >
        Comment ça marche
      </h2>
      <p class="m-0 text-lg leading-relaxed text-(--color-text-primary)/70">
        Découvrez comment votre nettoyage est géré, étape par étape — simple, rapide et conçu pour
        vous simplifier la vie.
      </p>
      <Button href="/contact" size="lg">Réserver votre nettoyage</Button>
    </div>

    <!-- Right: stacking step cards -->
    <div class="flex flex-col gap-4">
      {
        steps.map((step, i) => (
          <div
            data-hiw-step
            class="sticky flex flex-col gap-12 rounded-3xl bg-(--color-surface-secondary) p-8 lg:p-10"
            style={`top: calc(7.5rem + ${i * 0.5}rem); z-index: ${10 + i};`}
          >
            <span class="font-display text-7xl leading-none font-bold text-(--color-accent) lg:text-8xl">
              {step.number}
            </span>
            <div class="flex flex-col gap-4">
              <h3 class="font-display m-0 text-7xl font-bold text-(--color-text-primary)">
                {step.title}
              </h3>
              <p class="m-0 text-lg leading-relaxed text-(--color-text-primary)/60">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    // Left column slides in from the left
    const left = document.querySelector<HTMLElement>("[data-hiw-left]");
    if (left) {
      gsap.set(left, { x: -32, opacity: 0 });
      ScrollTrigger.create({
        trigger: left,
        start: "top 94%",
        once: true,
        onEnter: () => gsap.to(left, { x: 0, opacity: 1, duration: 0.7, ease: "power3.out" }),
      });
    }

    document.querySelectorAll<HTMLElement>("[data-hiw-step]").forEach((card, i) => {
      gsap.set(card, { y: 28, opacity: 0 });
      ScrollTrigger.create({
        trigger: card,
        start: "top 96%",
        once: true,
        onEnter: () =>
          gsap.to(card, { y: 0, opacity: 1, duration: 0.6, delay: i * 0.06, ease: "power3.out" }),
      });
    });
  }
</script>
