---
// Import the merging utilities
import { twMerge } from "tailwind-merge";
import { clsx, type ClassValue } from "clsx";

/**
 * Utility to merge Tailwind classes safely.
 * Content in 'className' will override defaults thanks to twMerge.
 */
function cn(...inputs: ClassValue[]) {
  return twMerge(clsx(inputs));
}

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  size?: "md" | "lg";
  class?: string;
  [key: string]: unknown;
}

const { href, type = "button", size = "md", class: className, ...rest } = Astro.props;
const Tag = href ? "a" : "button";

/**
 * Responsive Logic:
 * We set mobile-first defaults (smaller) and then use md: prefixes
 * to scale up to your original large sizes on desktops (min-width: 768px).
 */
const sizes = {
  md: {
    button: "px-4 py-1.5 text-base md:px-5 md:py-1.5 md:text-lg hover:pr-10 md:hover:pr-11",
    iconContainer: "right-3 h-4 w-4 translate-x-6 md:right-4",
    iconSvgClass: "w-4 h-4",
    textShift: "group-hover:-translate-x-1",
  },
  lg: {
    // Mobile: text-lg | Desktop: text-2xl
    button: "px-6 py-2.5 text-lg md:px-8 md:py-3 md:text-2xl hover:pr-14 md:hover:pr-16",
    iconContainer: "right-5 h-5 w-5 translate-x-8 md:right-6 md:h-6 md:w-6 md:translate-x-10",
    iconSvgClass: "w-5 h-5 md:w-6 md:h-6",
    textShift: "group-hover:-translate-x-2",
  },
};

const s = sizes[size];

const mergedClasses = cn(
  "group relative inline-flex cursor-pointer items-center overflow-hidden rounded-full whitespace-nowrap uppercase",
  "font-display font-bold no-underline transition-all duration-300 ease-in-out",
  "bg-(--color-accent) text-(--color-text-primary)",
  "hover:bg-(--color-text-primary) hover:text-(--color-background)",
  s.button,
  className
);
---

<Tag href={href} type={!href ? type : undefined} class={mergedClasses} {...rest}>
  <span class:list={["relative z-10 transition-transform duration-300 ease-in-out", s.textShift]}>
    <slot />
  </span>

  <span
    class:list={[
      "absolute top-1/2 z-10 flex -translate-y-1/2 items-center justify-center opacity-0 transition-all duration-300 ease-in-out group-hover:translate-x-0 group-hover:opacity-100",
      "text-inherit",
      s.iconContainer,
    ]}
    aria-hidden="true"
  >
    <svg class={s.iconSvgClass} viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M3.33337 8.00016H12.6667M12.6667 8.00016L8.00004 3.3335M12.6667 8.00016L8.00004 12.6668"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </span>
</Tag>
