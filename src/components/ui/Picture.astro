---
// Drop-in replacement for <img> that serves AVIF for .jpg/.jpeg sources.
// Use exactly as you would <img>: <Picture src="..." alt="..." class="..." />
// For non-JPEG sources (avif, webp, svg, png) it renders a plain <img>.

interface Props {
  src: string;
  alt: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  width?: number | string;
  height?: number | string;
  class?: string;
  [key: string]: unknown;
}

const { src, alt, loading = "lazy", fetchpriority, width = 1600, height = 900, class: className, ...imgAttrs } = Astro.props;
const isJpeg = /\.(jpg|jpeg)$/i.test(src);
const avifSrc = isJpeg ? src.replace(/\.(jpg|jpeg)$/i, ".avif") : null;
---

{
  isJpeg ? (
    <picture class="contents">
      <source srcset={avifSrc!} type="image/avif" width={width} height={height} />
      <img src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} width={width} height={height} class={className} {...imgAttrs} />
    </picture>
  ) : (
    <img src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} width={width} height={height} class={className} {...imgAttrs} />
  )
}
