---
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import type { Service } from "@/data/services";

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const isReversed = index % 2 !== 0;
---

<li data-service-card data-reversed={isReversed ? "true" : "false"}>
  <article
    class:list={[
      "group relative flex flex-col gap-5 md:gap-6",
      isReversed ? "md:flex-row-reverse" : "md:flex-row",
    ]}
  >
    <!-- Image -->
    <div
      data-service-image
      class="h-64 w-full shrink-0 overflow-hidden rounded-2xl md:h-105 md:w-2/5"
    >
      <Image
        src={service.image}
        alt=""
        widths={[400, 800]}
        sizes="(max-width: 767px) 100vw, 40vw"
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    </div>

    <!-- Content card -->
    <div
      data-service-content
      class="flex flex-1 flex-col justify-between gap-10 rounded-2xl bg-(--color-surface-secondary) p-8 md:p-12"
    >
      <div class="flex flex-col gap-5">
        <h2 class="font-display text-2xl font-bold md:text-5xl">{service.name}</h2>
        <p class="text-base leading-relaxed">{service.description}</p>
      </div>

      <Button href={service.href} size="lg" class="w-fit">Détails du service</Button>
    </div>
  </article>
</li>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const defer = (fn: () => void) => {
    if ("requestIdleCallback" in window) {
      requestIdleCallback(fn, { timeout: 2000 });
    } else {
      setTimeout(fn, 1);
    }
  };

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    defer(() => {
      document.querySelectorAll<HTMLElement>("[data-service-card]").forEach((card) => {
        const isReversed = card.dataset.reversed === "true";
        const image = card.querySelector<HTMLElement>("[data-service-image]");
        const content = card.querySelector<HTMLElement>("[data-service-content]");

        // Image: clip-path wipe from the outer edge inward
        // Even cards (ltr): image is on the left → wipe from left (inset 0 0 0 100% → 0)
        // Odd cards (rtl):  image is on the right → wipe from right (inset 0 100% 0 0 → 0)
        if (image) {
          const fromClip = isReversed ? "inset(0 100% 0 0)" : "inset(0 0 0 100%)";
          gsap.set(image, { clipPath: fromClip });
          ScrollTrigger.create({
            trigger: card,
            start: "top 94%",
            once: true,
            onEnter: () =>
              gsap.to(image, { clipPath: "inset(0 0% 0 0%)", duration: 1.1, ease: "expo.out" }),
          });
        }

        // Content: slides in from the opposite side with a slight delay
        if (content) {
          const fromX = isReversed ? -28 : 28;
          gsap.set(content, { x: fromX, opacity: 0 });
          ScrollTrigger.create({
            trigger: card,
            start: "top 94%",
            once: true,
            onEnter: () =>
              gsap.to(content, {
                x: 0,
                opacity: 1,
                duration: 0.85,
                delay: 0.18,
                ease: "power3.out",
              }),
          });
        }
      });
    });
  }
</script>
