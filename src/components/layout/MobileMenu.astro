---
import Button from "@components/ui/Button.astro";
import ServicesAllLink from "@components/ui/ServicesAllLink.astro";
import SocialLinks from "@components/ui/SocialLinks.astro";
import type { Service, NavLink } from "../../data/nav";

interface Props {
  services: Service[];
  navLinks: NavLink[];
}

const { services, navLinks } = Astro.props;

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";

const isActivePath = (href: string) => normalizePath(href) === currentPath;

const isServicesActive = currentPath === "/services" || currentPath.startsWith("/services/");
---

<div
  id="mobile-menu"
  class="font-accent pointer-events-none absolute inset-x-0 top-full z-40 -translate-y-2 opacity-0 transition-all duration-300 lg:hidden"
  aria-hidden="true"
>
  <div class="rounded-b-2xl bg-(--color-background) px-6 py-6">
    <div class="flex flex-col">
      <!-- Services accordion -->
      <div class="border-b border-(--color-border)/10">
        <button
          id="mobile-services-btn"
          type="button"
          class:list={[
            "flex w-full items-center justify-between py-4 text-2xl font-semibold tracking-[-0.02em] transition-colors duration-300 ease-out hover:text-(--color-accent)",
            isServicesActive ? "text-blue-600" : "text-(--color-text-primary)",
          ]}
        >
          Nos Services
          <span
            id="mobile-services-icon"
            class="flex h-8 w-8 flex-none items-center justify-center rounded-full bg-(--color-surface-secondary) transition-transform duration-300"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
            >
              <path
                d="M7 2V12M2 7H12"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"></path>
            </svg>
          </span>
        </button>
        <div id="mobile-services-panel" class="hidden flex-col gap-2 pb-5 pl-1">
          {
            services.map((s) => (
              <a
                href={s.href}
                class:list={[
                  "py-1 text-base font-medium tracking-[-0.01em] transition-colors duration-300 ease-out hover:text-(--color-accent)",
                  isActivePath(s.href) ? "text-blue-600" : "text-(--color-text-primary)/60",
                ]}
              >
                {s.name}
              </a>
            ))
          }
          <ServicesAllLink variant="mobile" />
        </div>
      </div>

      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "border-b border-(--color-border)/10 py-4 text-2xl font-semibold tracking-[-0.02em] transition-colors duration-300 ease-out hover:text-(--color-accent)",
              isActivePath(link.href) ? "text-blue-600" : "text-(--color-text-primary)",
            ]}
          >
            {link.name}
          </a>
        ))
      }

      <Button href="tel:+32486518181" class="mt-6 w-full justify-center">Appelez nous</Button>

      <div class="mt-6 flex flex-wrap items-center justify-between gap-4">
        <div></div>
        <SocialLinks />
      </div>
    </div>
  </div>
</div>
