---
import Container from "@components/ui/Container.astro";
import SocialLinks from "@components/ui/SocialLinks.astro";
import Button from "@components/ui/Button.astro";
import { imageAssets } from "@/data/images";
import { navLinks } from "../../data/nav";

const year = new Date().getFullYear();

const contactInfo = {
  phone: "+32 486 51 81 81",
  email: "clean-ngo@outlook.com",
};

const hours = [
  { day: "Lundi – Samedi", time: "8h – 18h" },
  { day: "Dimanche", time: "Fermé" },
];

const stats = [
  { value: "10+", label: "Années\nd'expérience" },
  { value: "98%", label: "Clients\nsatisfaits" },
  { value: "4.8", label: "Note\nmoyenne" },
];
---

<footer class="mt-8 w-full">
  <Container class="pb-8">
    <div class="overflow-hidden rounded-3xl bg-(--color-text-primary) text-(--color-surface)">
      <!-- Billboard — bold headline + CTA -->
      <div class="border-b border-(--color-surface)/10 px-8 py-12 md:px-14 md:py-16">
        <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
          <div class="flex flex-col gap-3">
            <p
              class="font-display text-xs font-bold tracking-[0.25em] text-(--color-accent) uppercase"
            >
              Votre partenaire propreté
            </p>
            <h2
              class="font-display text-5xl leading-none font-black tracking-tight text-(--color-surface) md:text-6xl lg:text-7xl"
            >
              Des espaces<br />impeccables.
            </h2>
          </div>
          <Button
            href="/contact"
            size="lg"
            data-umami-event="cta_click"
            data-umami-event-location="footer"
            class="hover:bg-(--color-surface) hover:text-(--color-text-primary)"
          >
            Contactez-nous
          </Button>
        </div>
      </div>

      <!-- Main grid -->
      <div
        class="grid grid-cols-1 gap-12 px-8 py-12 md:grid-cols-2 md:px-14 lg:grid-cols-3 lg:gap-10"
      >
        <!-- Col 1 — Brand + Stats -->
        <div class="flex flex-col gap-7">
          <a href="/" aria-label="CleanNgo – Accueil" class="group w-fit">
            <img
              src={imageAssets.brandLogo}
              alt="CleanNgo"
              class="h-16 w-auto brightness-0 invert transition-opacity duration-200 group-hover:opacity-60"
            />
          </a>

          <p class="max-w-xs text-base leading-relaxed text-(--color-surface)/60">
            Des espaces impeccables, une équipe de confiance. Votre propreté, notre fierté.
          </p>

          <!-- Typography variation — stats as display figures -->
          <div class="grid grid-cols-3 gap-3 border-t border-(--color-surface)/10 pt-6">
            {
              stats.map((stat) => (
                <div class="flex flex-col gap-1.5">
                  <span class="font-accent text-3xl leading-none font-black text-(--color-accent)">
                    {stat.value}
                  </span>
                  <span class="text-xs leading-tight whitespace-pre-line text-(--color-surface)/65">
                    {stat.label}
                  </span>
                </div>
              ))
            }
          </div>

          <div class="mt-auto text-(--color-surface)/50">
            <SocialLinks />
          </div>
        </div>

        <!-- Col 2 — Navigation -->
        <div class="flex flex-col gap-6">
          <p class="font-display text-xl font-bold tracking-widest text-(--color-accent) uppercase">
            Navigation
          </p>
          <ul class="flex flex-col gap-3.5">
            <li>
              <a
                href="/"
                class="text-base text-(--color-surface)/70 transition-colors duration-200 hover:text-(--color-accent)"
              >
                Accueil
              </a>
            </li>
            <li>
              <a
                href="/services"
                class="text-base text-(--color-surface)/70 transition-colors duration-200 hover:text-(--color-accent)"
              >
                Tous nos services
              </a>
            </li>
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-base text-(--color-surface)/70 transition-colors duration-200 hover:text-(--color-accent)"
                  >
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Col 3 — Contact & Hours -->
        <div class="flex flex-col gap-6">
          <p class="font-display text-xl font-bold tracking-widest text-(--color-accent) uppercase">
            Contact
          </p>

          <div class="flex flex-col gap-4">
            <!-- Phone -->
            <a
              href={`tel:${contactInfo.phone.replace(/\s/g, "")}`}
              data-umami-event="phone_click"
              class="group flex items-center gap-4 text-(--color-surface)/70 transition-colors duration-200 hover:text-(--color-accent)"
            >
              <span
                class="flex size-10 shrink-0 items-center justify-center rounded-full bg-(--color-surface)/10 transition-colors duration-200 group-hover:bg-(--color-accent)/20"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path>
                </svg>
              </span>
              <span class="text-base font-medium">{contactInfo.phone}</span>
            </a>

            <!-- Email -->
            <a
              href={`mailto:${contactInfo.email}`}
              data-umami-event="email_click"
              class="group flex items-center gap-4 text-(--color-surface)/70 transition-colors duration-200 hover:text-(--color-accent)"
            >
              <span
                class="flex size-10 shrink-0 items-center justify-center rounded-full bg-(--color-surface)/10 transition-colors duration-200 group-hover:bg-(--color-accent)/20"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
              </span>
              <span class="text-base font-medium">{contactInfo.email}</span>
            </a>
          </div>

          <!-- Hours -->
          <div class="flex flex-col gap-4 border-t border-(--color-surface)/10 pt-5">
            <p
              class="font-display text-xs font-bold tracking-widest text-(--color-accent) uppercase"
            >
              Horaires
            </p>
            <div class="grid grid-cols-3 gap-3">
              {
                hours.map((entry) => (
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] leading-none font-bold tracking-widest text-(--color-surface)/65 uppercase">
                      {entry.day}
                    </span>
                    <span
                      class:list={[
                        "font-accent text-xl leading-none font-black tabular-nums",
                        entry.time === "Fermé"
                          ? "text-(--color-surface)/25"
                          : "text-(--color-surface)",
                      ]}
                    >
                      {entry.time}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom bar -->
      <div
        class="flex flex-col items-center justify-between gap-4 border-t border-(--color-surface)/10 px-8 py-6 sm:flex-row md:px-14"
      >
        <p class="text-sm text-(--color-surface)/65">
          © {year} CleanNgo. Tous droits réservés.
        </p>
        <div class="flex items-center gap-6 text-sm text-(--color-surface)/65">
          <a
            href="/politique-de-confidentialite"
            class="transition-colors duration-200 hover:text-(--color-accent)"
          >
            Politique de confidentialité
          </a>
          <a
            href="/mentions-legales"
            class="transition-colors duration-200 hover:text-(--color-accent)"
          >
            Mentions légales
          </a>
        </div>
      </div>
    </div>
  </Container>
</footer>
