---
import "@styles/global.css";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import type { SEOMeta } from "@/types/index";

interface Props extends SEOMeta {
  class?: string;
}

const {
  title,
  description,
  image = "/og-image.png",
  noindex = false,
  class: className,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://example.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const siteName = "My Client Website";
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fontlibrary.org//face/decalotype" type="text/css" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inject additional head tags per-page -->
    <slot name="head" />
  </head>

  <body class:list={["flex min-h-dvh flex-col", className]}>
    <Header />
    <main class="flex-1 pt-18">
      <slot />
    </main>
    <Footer />
  </body>
</html>
