---
import "@styles/global.css";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import type { SEOMeta } from "@/types/index";

interface Props extends SEOMeta {
  class?: string;
}

const {
  title,
  description,
  image = "/og-image.png",
  noindex = false,
  class: className,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://example.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const siteName = "CleanNgo";
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="fr-BE" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Font preloads — Regular + Bold for each family (most-used weights) -->
    <link
      rel="preload"
      href="/fonts/Decalotype-Regular-fix.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Decalotype-Black-fix.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/BricolageGrotesque-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/BricolageGrotesque-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- LocalBusiness structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "CleanNgo",
      "url": "https://cleanngo.be",
      "telephone": "+32486518181",
      "email": "clean-ngo@outlook.com",
      "image": `${siteUrl}/og-image.png`,
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bruxelles",
        "addressRegion": "Bruxelles-Capitale",
        "addressCountry": "BE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 50.8503,
        "longitude": 4.3517
      },
      "areaServed": [
        "Bruxelles", "Uccle", "Ixelles", "Etterbeek", "Waterloo",
        "Wavre", "Ottignies", "Louvain-la-Neuve", "Nivelles",
        "Braine-l'Alleud", "Lasne", "Genappe"
      ].map(name => ({ "@type": "City", name })),
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
          "opens": "08:00",
          "closes": "18:00"
        }
      ]
    })} />

    <!-- Inject additional head tags per-page -->
    <slot name="head" />
  </head>

  <body class:list={["flex min-h-dvh flex-col", className]}>
    <Header />
    <main class="flex-1 pt-18">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { splitWords, magneticEffect } from "@/lib/animations";

  gsap.registerPlugin(ScrollTrigger);

  // Respect user's motion preference
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    // ── Header scroll state ────────────────────────────────
    // Synchronous: single, lightweight ScrollTrigger — safe to run immediately.
    const header = document.getElementById("site-header");
    if (header) {
      ScrollTrigger.create({
        start: "top -72px",
        end: 99999,
        onEnter: () => header.setAttribute("data-scrolled", ""),
        onLeaveBack: () => header.removeAttribute("data-scrolled"),
      });
    }

    // Each reveal group runs in its own macrotask (setTimeout 0).
    // This lets the browser render a frame between each batch so no single
    // task blocks long enough to inflate TBT.

    // ── Word-reveal headings ───────────────────────────────
    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('[data-reveal="words"]').forEach((el) => {
        const spans = splitWords(el);
        gsap.set(spans, { y: "105%" });
        // Unhide the container — CSS hides it to prevent FOUC; now the words
        // are clipped by their overflow:hidden wrappers so nothing shows yet.
        gsap.set(el, { opacity: 1 });
        ScrollTrigger.create({
          trigger: el,
          start: "top 96%",
          once: true,
          onEnter: () => {
            gsap.to(spans, { y: "0%", duration: 0.75, stagger: 0.035, ease: "power3.out" });
          },
        });
      });
    }, 0);

    // ── Fade-up elements ───────────────────────────────────
    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('[data-reveal="fade"]').forEach((el) => {
        gsap.set(el, { y: 22, opacity: 0 });
        ScrollTrigger.create({
          trigger: el,
          start: "top 98%",
          once: true,
          onEnter: () => {
            gsap.to(el, { y: 0, opacity: 1, duration: 0.65, ease: "power3.out" });
          },
        });
      });
    }, 0);

    // ── Wipe-in images & blocks ────────────────────────────
    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('[data-reveal="wipe"]').forEach((el) => {
        gsap.set(el, { clipPath: "inset(100% 0 0 0)" });
        ScrollTrigger.create({
          trigger: el,
          start: "top 94%",
          once: true,
          onEnter: () => {
            gsap.to(el, { clipPath: "inset(0% 0 0 0)", duration: 1, ease: "expo.out" });
          },
        });
      });
    }, 0);

    // ── Staggered cards / items ────────────────────────────
    setTimeout(() => {
      document.querySelectorAll<HTMLElement>('[data-reveal="cards"]').forEach((container) => {
        const cards = Array.from(container.children) as HTMLElement[];
        gsap.set(cards, { y: 32, opacity: 0 });
        ScrollTrigger.create({
          trigger: container,
          start: "top 94%",
          once: true,
          onEnter: () => {
            gsap.to(cards, { y: 0, opacity: 1, duration: 0.6, stagger: 0.08, ease: "power3.out" });
          },
        });
      });
    }, 0);

    // ── Magnetic buttons ───────────────────────────────────
    setTimeout(() => {
      magneticEffect("[data-magnetic]", 0.22);
    }, 0);
  }
</script>
