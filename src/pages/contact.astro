---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import SectionLabel from "@components/ui/SectionLabel.astro";
import Button from "@components/ui/Button.astro";
import { services } from "@/data/services";

const reviews = [
  {
    text: "Rentrer chez moi après leur passage, c'est comme retrouver un appartement neuf. Calme, propre et frais.",
    platform: "Avis Google",
  },
  {
    text: "J'ai essayé d'autres services, mais CleanNgo est dans une autre catégorie. Attentionnés, soigneux et constants.",
    platform: "Avis Google",
  },
  {
    text: "J'adore qu'ils utilisent des produits naturels — mes enfants et mon chien sont en sécurité, et tout sent divinement bon.",
    platform: "Avis Google",
  },
  {
    text: "Ponctualité parfaite, travail impeccable. Je recommande CleanNgo les yeux fermés à toute ma famille.",
    platform: "Avis Google",
  },
];

const marqueeReviews = [...reviews, ...reviews, ...reviews];
---

<BaseLayout
  title="Devis gratuit nettoyage vitres, toitures & façades | CleanNgo"
  description="Demandez un devis gratuit. CleanNgo nettoie vitres, toitures, façades et panneaux solaires à Bruxelles et périphérie, avec réponse sous 2 heures."
>
  <Container class="pt-12 pb-24 md:pt-20">
    <section class="mx-auto mb-12 flex max-w-4xl flex-col items-center gap-8 text-center">
      <SectionLabel text="Réserver" bg="bg-(--color-surface-secondary)" />

      <h1
        data-reveal="words"
        class="font-display text-4xl leading-[0.85] font-bold uppercase md:text-8xl"
      >
        Demandez votre devis gratuit à Bruxelles
      </h1>

      <p data-reveal="fade" class="max-w-2xl text-lg text-(--color-text-primary)/70 md:text-xl">
        Faites votre demande en ligne, nous vous confirmons par téléphone ou SMS dans les 2 heures.
        Sans frais cachés, sans mauvaise surprise.
      </p>

      <div class="mt-2 flex w-full items-center justify-center">
        <a
          href="https://www.google.com/search?q=Clean+Ngo&ludocid=9735946715667628061&ibp=gwp;0,7"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Consultez nos 4.9 étoiles sur Google"
          data-umami-event="google_reviews_click"
          data-umami-event-location="contact_page"
          data-umami-event-channel="google"
          class="group flex w-fit items-center gap-3 rounded-full bg-(--color-surface-secondary) p-1 pr-5 transition-all duration-300 hover:ring-1 hover:ring-(--color-border)/20"
        >
          <div
            class="flex size-8 shrink-0 items-center justify-center rounded-full bg-white shadow-sm transition-transform duration-300 group-hover:scale-110 sm:size-9"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 48 48"
              xmlns="http://www.w3.org/2000/svg"
              class="sm:size-5"
            >
              <path
                fill="#EA4335"
                d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"
              ></path>
              <path
                fill="#4285F4"
                d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"
              ></path>
              <path
                fill="#FBBC05"
                d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24s.92 7.54 2.56 10.78l7.97-6.19z"
              ></path>
              <path
                fill="#34A853"
                d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"
              ></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold tracking-widest uppercase sm:text-sm"
            >4.9 sur Google</span
          >
        </a>
      </div>
    </section>

    <section class="mx-auto w-full max-w-4xl">
      <!-- Formulaire de réservation -->
      <div data-form-card class="rounded-3xl bg-(--color-surface-secondary) p-6 sm:p-10 lg:p-12">
        <div data-form-header class="mb-8">
          <h2 class="font-display text-3xl font-bold">Réservez en 60 secondes</h2>
          <p class="font-medium text-(--color-text-primary)/60">
            Pour ceux qui préfèrent réserver instantanément.
          </p>
        </div>

        <form id="booking-form" novalidate class="flex flex-col gap-5">
          <!-- Nom complet -->
          <div data-form-field class="flex flex-col gap-1.5">
            <label for="name" class="text-xs font-bold tracking-widest uppercase opacity-60"
              >Nom complet <span aria-hidden="true" class="text-(--color-accent)">*</span></label
            >
            <div class="input-wrap group relative flex items-center">
              <span
                class="pointer-events-none absolute left-4 text-(--color-text-primary)/30 transition-colors group-focus-within:text-(--color-accent)"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M20 21C20 19.1362 20 18.2044 19.6955 17.4693C19.2895 16.4892 18.5108 15.7105 17.5307 15.3045C16.7956 15 15.8638 15 14 15H10C8.13623 15 7.20435 15 6.46927 15.3045C5.48915 15.7105 4.71046 16.4892 4.30448 17.4693C4 18.2044 4 19.1362 4 21M16 7C16 9.20914 14.2091 11 12 11C9.79086 11 8 9.20914 8 7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Jean Dupont"
                autocomplete="name"
                maxlength="100"
                aria-required="true"
                aria-describedby="name-error"
                class="field-input w-full rounded-xl border-none bg-white py-3.5 pr-5 pl-11 text-(--color-text-primary) transition-all duration-200 placeholder:text-(--color-text-primary)/30 focus:shadow-[0_0_0_4px_color-mix(in_srgb,var(--color-accent)_12%,transparent)] focus:outline-none"
              />
            </div>
            <p
              id="name-error"
              class="field-error hidden text-xs font-semibold text-red-500"
              data-field="name"
            >
              Veuillez entrer votre nom complet.
            </p>
          </div>

          <!-- Téléphone + Email (au moins un requis) -->
          <fieldset data-form-field class="m-0 flex flex-col gap-1.5 border-0 p-0">
            <legend class="mb-1.5 flex w-full items-baseline justify-between">
              <span class="text-xs font-bold tracking-widest uppercase opacity-60">Contact</span>
              <span class="text-xs font-semibold text-(--color-text-primary)/65"
                >Au moins l'un des deux</span
              >
            </legend>
            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              <div class="input-wrap group relative flex items-center">
                <span
                  class="pointer-events-none absolute left-4 text-(--color-text-primary)/30 transition-colors group-focus-within:text-(--color-accent)"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M18.444 22.0907C18.7193 22.2172 19.0296 22.246 19.3236 22.1726C19.6175 22.0992 19.8777 21.9278 20.0613 21.6867L20.5346 21.0667C20.783 20.7355 21.1051 20.4667 21.4754 20.2815C21.8457 20.0964 22.254 20 22.668 20H26.668C27.3752 20 28.0535 20.281 28.5536 20.7811C29.0537 21.2812 29.3346 21.9594 29.3346 22.6667V26.6667C29.3346 27.3739 29.0537 28.0522 28.5536 28.5523C28.0535 29.0524 27.3752 29.3334 26.668 29.3334C20.3028 29.3334 14.1983 26.8048 9.69741 22.3039C5.19653 17.803 2.66797 11.6985 2.66797 5.33335C2.66797 4.62611 2.94892 3.94783 3.44902 3.44774C3.94911 2.94764 4.62739 2.66669 5.33464 2.66669H9.33464C10.0419 2.66669 10.7202 2.94764 11.2203 3.44774C11.7203 3.94783 12.0013 4.62611 12.0013 5.33335V9.33335C12.0013 9.74734 11.9049 10.1556 11.7198 10.5259C11.5346 10.8962 11.2658 11.2183 10.9346 11.4667L10.3106 11.9347C10.0659 12.1216 9.89333 12.3875 9.82236 12.6872C9.75138 12.9868 9.78635 13.3019 9.9213 13.5787C11.7435 17.2798 14.7405 20.2731 18.444 22.0907Z"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      transform="scale(0.72) translate(3.3 3.3)"></path>
                  </svg>
                </span>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  placeholder="+32 486 00 00 00"
                  autocomplete="tel"
                  aria-describedby="contact-error"
                  class="field-input w-full rounded-xl border-none bg-white py-3.5 pr-5 pl-11 text-(--color-text-primary) transition-all duration-200 placeholder:text-(--color-text-primary)/30 focus:shadow-[0_0_0_4px_color-mix(in_srgb,var(--color-accent)_12%,transparent)] focus:outline-none"
                />
              </div>
              <div class="input-wrap group relative flex items-center">
                <span
                  class="pointer-events-none absolute left-4 text-(--color-text-primary)/30 transition-colors group-focus-within:text-(--color-accent)"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M2 7L10.1649 12.7154C10.8261 13.1783 11.1567 13.4097 11.5163 13.4993C11.8339 13.5785 12.1661 13.5785 12.4837 13.4993C12.8433 13.4097 13.1739 13.1783 13.8351 12.7154L22 7M6.8 20H17.2C18.8802 20 19.7202 20 20.362 19.673C20.9265 19.3854 21.3854 18.9265 21.673 18.362C22 17.7202 22 16.8802 22 15.2V8.8C22 7.11984 22 6.27976 21.673 5.63803C21.3854 5.07354 20.9265 4.6146 20.362 4.32698C19.7202 4 18.8802 4 17.2 4H6.8C5.11984 4 4.27976 4 3.63803 4.32698C3.07354 4.6146 2.6146 5.07354 2.32698 5.63803C2 6.27976 2 7.11984 2 8.8V15.2C2 16.8802 2 17.7202 2.32698 18.362C2.6146 18.9265 3.07354 19.3854 3.63803 19.673C4.27976 20 5.11984 20 6.8 20Z"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </span>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="jean@exemple.be"
                  autocomplete="email"
                  aria-describedby="contact-error"
                  class="field-input w-full rounded-xl border-none bg-white py-3.5 pr-5 pl-11 text-(--color-text-primary) transition-all duration-200 placeholder:text-(--color-text-primary)/30 focus:shadow-[0_0_0_4px_color-mix(in_srgb,var(--color-accent)_12%,transparent)] focus:outline-none"
                />
              </div>
            </div>
            <p
              id="contact-error"
              class="field-error hidden text-xs font-semibold text-red-500"
              data-field="contact"
            >
              Veuillez renseigner un numéro de téléphone ou une adresse e-mail valide.
            </p>
          </fieldset>

          <!-- Ville -->
          <div data-form-field class="flex flex-col gap-1.5">
            <label for="city" class="text-xs font-bold tracking-widest uppercase opacity-60"
              >Ville <span aria-hidden="true" class="text-(--color-accent)">*</span></label
            >
            <div class="input-wrap group relative flex items-center">
              <span
                class="pointer-events-none absolute left-4 text-(--color-text-primary)/30 transition-colors group-focus-within:text-(--color-accent)"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M12 22C16 18 20 14.4183 20 10C20 5.58172 16.4183 2 12 2C7.58172 2 4 5.58172 4 10C4 14.4183 8 18 12 22Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
              <input
                id="city"
                name="city"
                type="text"
                placeholder="Bruxelles"
                autocomplete="address-level2"
                list="city-suggestions"
                aria-required="true"
                aria-describedby="city-error"
                class="field-input w-full rounded-xl border-none bg-white py-3.5 pr-5 pl-11 text-(--color-text-primary) transition-all duration-200 placeholder:text-(--color-text-primary)/30 focus:shadow-[0_0_0_4px_color-mix(in_srgb,var(--color-accent)_12%,transparent)] focus:outline-none"
              />
              <datalist id="city-suggestions">
                <option value="Bruxelles"></option>
                <option value="Ixelles"></option>
                <option value="Etterbeek"></option>
                <option value="Uccle"></option>
                <option value="Schaerbeek"></option>
                <option value="Woluwe-Saint-Lambert"></option>
                <option value="Woluwe-Saint-Pierre"></option>
                <option value="Auderghem"></option>
                <option value="Watermael-Boitsfort"></option>
                <option value="Forest"></option>
                <option value="Anderlecht"></option>
                <option value="Molenbeek-Saint-Jean"></option>
                <option value="Saint-Gilles"></option>
                <option value="Saint-Josse-ten-Noode"></option>
                <option value="Laeken"></option>
                <option value="Evere"></option>
                <option value="Jette"></option>
                <option value="Koekelberg"></option>
                <option value="Berchem-Sainte-Agathe"></option>
                <option value="Ganshoren"></option>
                <option value="Waterloo"></option>
                <option value="Rhode-Saint-Genèse"></option>
                <option value="Rixensart"></option>
                <option value="Overijse"></option>
                <option value="Kraainem"></option>
                <option value="Wezembeek-Oppem"></option>
                <option value="Tervuren"></option>
                <option value="Zaventem"></option>
                <option value="Vilvoorde"></option>
                <option value="Mechelen"></option>
              </datalist>
            </div>
            <p
              id="city-error"
              class="field-error hidden text-xs font-semibold text-red-500"
              data-field="city"
            >
              Veuillez indiquer votre ville.
            </p>
          </div>

          <!-- Services (multi-select chips) -->
          <div data-form-field class="flex flex-col gap-2">
            <div class="flex items-baseline justify-between">
              <span class="text-xs font-bold tracking-widest uppercase opacity-60"
                >Service(s) souhaité(s) <span aria-hidden="true" class="text-(--color-accent)"
                  >*</span
                ></span
              >
              <span class="text-xs font-semibold text-(--color-text-primary)/65"
                >Sélection multiple</span
              >
            </div>
            <div
              class="flex flex-wrap gap-2"
              role="group"
              aria-label="Sélectionnez vos services"
              aria-required="true"
              aria-describedby="services-error"
            >
              {
                services.map((service: (typeof services)[number]) => (
                  <label class="service-chip cursor-pointer select-none">
                    <input
                      type="checkbox"
                      name="services"
                      value={service.href.split("/").pop()}
                      class="peer sr-only"
                    />
                    <span class="block rounded-xl border-none bg-white px-4 py-2 text-sm font-semibold text-(--color-text-primary)/70 transition-all duration-150 peer-checked:bg-(--color-accent) peer-checked:text-(--color-text-primary) peer-focus-visible:ring-2 peer-focus-visible:ring-(--color-accent) peer-focus-visible:ring-offset-1 hover:text-(--color-text-primary)">
                      {service.name}
                    </span>
                  </label>
                ))
              }
            </div>
            <p
              id="services-error"
              class="field-error hidden text-xs font-semibold text-red-500"
              data-field="services"
            >
              Veuillez sélectionner au moins un service.
            </p>
          </div>

          <!-- Fréquence d'intervention -->
          <div data-form-field class="flex flex-col gap-2">
            <div class="flex items-baseline justify-between">
              <span class="text-xs font-bold tracking-widest uppercase opacity-60"
                >Fréquence souhaitée <span aria-hidden="true" class="text-(--color-accent)">*</span
                ></span
              >
            </div>
            <div
              class="flex flex-wrap gap-2"
              role="radiogroup"
              aria-label="Sélectionnez la fréquence"
              aria-required="true"
              aria-describedby="frequency-error"
            >
              {
                [
                  { label: "Ponctuel", value: "ponctuel" },
                  { label: "Hebdomadaire", value: "hebdomadaire" },
                  { label: "Toutes les 2 semaines", value: "bimensuel" },
                  { label: "Mensuel", value: "mensuel" },
                ].map((opt) => (
                  <label class="frequency-chip cursor-pointer select-none">
                    <input type="radio" name="frequency" value={opt.value} class="peer sr-only" />
                    <span class="block rounded-xl border-none bg-white px-4 py-2 text-sm font-semibold text-(--color-text-primary)/70 transition-all duration-150 peer-checked:bg-(--color-accent) peer-checked:text-(--color-text-primary) peer-focus-visible:ring-2 peer-focus-visible:ring-(--color-accent) peer-focus-visible:ring-offset-1 hover:text-(--color-text-primary)">
                      {opt.label}
                    </span>
                  </label>
                ))
              }
            </div>
            <p
              id="frequency-error"
              class="field-error hidden text-xs font-semibold text-red-500"
              data-field="frequency"
            >
              Veuillez sélectionner une fréquence d'intervention.
            </p>
          </div>

          <!-- Notes -->
          <div data-form-field class="flex flex-col gap-1.5">
            <label for="notes" class="text-xs font-bold tracking-widest uppercase opacity-60"
              >Informations complémentaires</label
            >
            <textarea
              id="notes"
              name="notes"
              rows="4"
              maxlength="1000"
              placeholder="Surface approximative, accès au logement, animaux de compagnie, instructions particulières, disponibilités..."
              class="w-full resize-none rounded-xl border-none bg-white px-5 py-3.5 text-(--color-text-primary) transition-all duration-200 placeholder:text-(--color-text-primary)/30 focus:shadow-[0_0_0_4px_color-mix(in_srgb,var(--color-accent)_12%,transparent)] focus:outline-none"
            ></textarea>
          </div>

          <!-- Network error message -->
          <div
            id="form-error"
            role="alert"
            class="hidden rounded-2xl border border-red-200 bg-red-50 px-6 py-4 text-center"
          >
            <p class="font-bold text-red-700">Une erreur est survenue.</p>
            <p class="text-sm text-red-600">Veuillez réessayer ou nous contacter par téléphone.</p>
          </div>

          <!-- Confirmation success message -->
          <div
            id="form-success"
            role="alert"
            class="hidden rounded-2xl border border-green-200 bg-green-50 px-6 py-4 text-center"
          >
            <p class="font-bold text-green-700">Demande envoyée !</p>
            <p class="text-sm text-green-600">Nous vous confirmons par téléphone dans les 2h.</p>
          </div>

          <!-- Honeypot – invisible to humans, filled by bots -->
          <div aria-hidden="true" class="absolute -top-[9999px] -left-[9999px] overflow-hidden">
            <label for="website">Ne pas remplir</label>
            <input id="website" name="website" type="text" autocomplete="off" tabindex="-1" />
          </div>

          <div
            data-form-field
            class="mt-2 flex flex-col items-center justify-between gap-6 border-t border-(--color-border)/10 pt-6 sm:flex-row"
          >
            <p class="max-w-62.5 text-sm font-medium text-(--color-text-primary)/60">
              Confirmation par appel ou SMS. Aucun frais caché, jamais.
            </p>
            <Button type="submit" size="lg" class="w-full justify-center sm:w-auto">
              Envoyer ma demande
            </Button>
          </div>
        </form>
      </div>
    </section>

    <section class="mx-auto mt-4 w-full max-w-4xl">
      <h2 data-reveal="words" class="font-display mb-4 text-3xl font-bold">
        Vous préférez parler ?
      </h2>
      <div data-reveal="cards" class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <a
          href="tel:+32486518181"
          data-umami-event="phone_click"
          data-umami-event-location="contact_page"
          data-umami-event-channel="phone"
          class="group flex items-center gap-6 rounded-3xl bg-(--color-surface-secondary) p-8 transition-colors hover:bg-(--color-accent) hover:text-(--color-text-primary)"
        >
          <div
            class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-white text-(--color-text-primary) transition-colors group-hover:bg-(--color-text-primary)/10"
          >
            <svg
              width="28"
              height="28"
              viewBox="0 0 32 32"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
