  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const card = document.querySelector<HTMLElement>("[data-form-card]");
    const header = document.querySelector<HTMLElement>("[data-form-header]");
    const fields = document.querySelectorAll<HTMLElement>("[data-form-field]");

    // 1. Card wipes in from the bottom
    if (card) {
      gsap.set(card, { clipPath: "inset(100% 0 0 0)" });
      ScrollTrigger.create({
        trigger: card,
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(card, { clipPath: "inset(0% 0 0 0)", duration: 1, ease: "expo.out" }),
      });
    }

    // 2. Form header fades in after card starts revealing
    if (header) {
      gsap.set(header, { y: 16, opacity: 0 });
      ScrollTrigger.create({
        trigger: card ?? header,
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(header, { y: 0, opacity: 1, duration: 0.7, delay: 0.3, ease: "power3.out" }),
      });
    }

    // 3. Each field group staggers in after the header
    if (fields.length) {
      gsap.set(fields, { y: 20, opacity: 0 });
      ScrollTrigger.create({
        trigger: card ?? fields[0],
        start: "top 94%",
        once: true,
        onEnter: () =>
          gsap.to(fields, {
            y: 0,
            opacity: 1,
            duration: 0.6,
            stagger: 0.07,
            delay: 0.5,
            ease: "power3.out",
          }),
      });
    }

    // 4. Input focus micro-interaction — subtle scale on the wrapper
    document.querySelectorAll<HTMLElement>(".input-wrap").forEach((wrap) => {
      const input = wrap.querySelector("input");
      input?.addEventListener("focus", () =>
        gsap.to(wrap, { scale: 1.015, duration: 0.2, ease: "power2.out" })
      );
      input?.addEventListener("blur", () =>
        gsap.to(wrap, { scale: 1, duration: 0.25, ease: "power2.inOut" })
      );
    });

    // 5. Service chip selection — bounce on toggle
    document.querySelectorAll<HTMLElement>(".service-chip").forEach((chip) => {
      const checkbox = chip.querySelector("input");
      const label = chip.querySelector("span");
      checkbox?.addEventListener("change", () => {
        if (label)
          gsap.fromTo(label, { scale: 0.88 }, { scale: 1, duration: 0.35, ease: "back.out(2.5)" });
      });
    });

    // 5b. Frequency chip selection — bounce on select
    document.querySelectorAll<HTMLElement>(".frequency-chip").forEach((chip) => {
      const radio = chip.querySelector("input");
      const label = chip.querySelector("span");
      radio?.addEventListener("change", () => {
        if (label)
          gsap.fromTo(label, { scale: 0.88 }, { scale: 1, duration: 0.35, ease: "back.out(2.5)" });
      });
    });

    // 6. Success message animates in when revealed by the form script
    const successEl = document.getElementById("form-success");
    if (successEl) {
      const observer = new MutationObserver(() => {
        if (!successEl.classList.contains("hidden")) {
          gsap.from(successEl, { y: -14, opacity: 0, duration: 0.5, ease: "back.out(1.5)" });
        }
      });
      observer.observe(successEl, { attributes: true, attributeFilter: ["class"] });
    }
  }
</script>

<script>
  // TODO: replace with your actual backend / form service endpoint
  const FORM_ENDPOINT = "/api/contact";

  const form = document.getElementById("booking-form") as HTMLFormElement;
  const successMsg = document.getElementById("form-success");
  const errorMsg = document.getElementById("form-error");

  type UmamiWindow = Window & {
    umami?: { track(name: string, data?: Record<string, string>): void };
  };
  const umamiTrack = (name: string, data?: Record<string, string>) =>
    (window as UmamiWindow).umami?.track(name, data);

  function isValidPhone(v: string) {
    return /^\+?[\d\s\-().]{7,20}$/.test(v.trim());
  }
  function isValidEmail(v: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
  }

  function setError(field: string, show: boolean, inputIds: string[] = [field]) {
    const msg = form.querySelector(`[data-field="${field}"]`) as HTMLElement | null;
    msg?.classList.toggle("hidden", !show);
    for (const id of inputIds) {
      const el = form.querySelector(`#${id}`) as HTMLElement | null;
      el?.classList.toggle("!shadow-[0_0_0_2px_theme(colors.red.400)]", show);
      el?.setAttribute("aria-invalid", show ? "true" : "false");
    }
  }

  // Live clearing of errors as user types / changes
  form?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    if (!target.name) return;
    if (target.name === "phone" || target.name === "email") {
      setError("contact", false, ["phone", "email"]);
    } else if (target.name === "services") {
      setError("services", false);
    } else if (target.name === "frequency") {
      setError("frequency", false);
    } else {
      setError(target.name, false);
    }
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    let valid = true;

    const name = (form.querySelector("#name") as HTMLInputElement).value.trim();
    const phone = (form.querySelector("#phone") as HTMLInputElement).value.trim();
    const email = (form.querySelector("#email") as HTMLInputElement).value.trim();
    const city = (form.querySelector("#city") as HTMLInputElement).value.trim();
    const selectedServices = form.querySelectorAll('input[name="services"]:checked');
    const selectedFrequency = form.querySelector('input[name="frequency"]:checked');
    const frequencyValue = (selectedFrequency as HTMLInputElement | null)?.value ?? "none";

    // Honeypot check – abort silently if filled by a bot
    const honeypot = (form.querySelector("#website") as HTMLInputElement)?.value;
    if (honeypot) return;

    if (!name) {
      setError("name", true);
      valid = false;
    } else {
      setError("name", false);
    }

    const phoneOk = phone && isValidPhone(phone);
    const emailOk = email && isValidEmail(email);
    if (!phoneOk && !emailOk) {
      setError("contact", true, ["phone", "email"]);
      valid = false;
    } else {
      setError("contact", false, ["phone", "email"]);
    }

    if (!city) {
      setError("city", true);
      valid = false;
    } else {
      setError("city", false);
    }

    if (selectedServices.length === 0) {
      setError("services", true);
      valid = false;
    } else {
      setError("services", false);
    }

    if (!selectedFrequency) {
      setError("frequency", true);
      valid = false;
    } else {
      setError("frequency", false);
    }

    if (!valid) {
      umamiTrack("contact_form_validation_error", {
        page: "contact",
        has_name: String(Boolean(name)),
        has_phone: String(Boolean(phone)),
        has_email: String(Boolean(email)),
        has_city: String(Boolean(city)),
        services_count: String(selectedServices.length),
        has_frequency: String(Boolean(selectedFrequency)),
      });
      form
        .querySelector(".field-error:not(.hidden)")
        ?.scrollIntoView({ behavior: "smooth", block: "center" });
      return;
    }

    umamiTrack("contact_form_submit_attempt", {
      page: "contact",
      services_count: String(selectedServices.length),
      frequency: frequencyValue,
      contact_method: phoneOk && emailOk ? "phone_email" : phoneOk ? "phone" : "email",
    });

    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.disabled = true;
    const originalLabel = btn.textContent ?? "";
    btn.textContent = "Envoi en cours…";
    errorMsg?.classList.add("hidden");

    try {
      const formData = new FormData(form);
      const payload = Object.fromEntries(
        Array.from(formData.keys()).map((key) => [key, formData.getAll(key).join(", ")])
      );
      const res = await fetch(FORM_ENDPOINT, {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      successMsg?.classList.remove("hidden");
      umamiTrack("contact_form_submit", {
        page: "contact",
        services_count: String(selectedServices.length),
        frequency: frequencyValue,
        contact_method: phoneOk && emailOk ? "phone_email" : phoneOk ? "phone" : "email",
      });
      form.querySelectorAll("input, textarea, button[type=submit]").forEach((el) => {
        (el as HTMLInputElement | HTMLTextAreaElement | HTMLButtonElement).disabled = true;
      });
    } catch {
      errorMsg?.classList.remove("hidden");
      umamiTrack("contact_form_error", { page: "contact", source: "booking_form_submit" });
      btn.disabled = false;
      btn.textContent = originalLabel;
    }
  });
</script>
