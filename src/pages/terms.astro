---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
---

<BaseLayout
  title="Mentions légales"
  description="Mentions légales de CleanNgo, entreprise de nettoyage à Bruxelles."
  noindex={true}
>
  <Container class="py-20">
    <div class="mx-auto max-w-2xl">
      <h1 class="font-display mb-8 text-4xl font-bold uppercase md:text-5xl">
        Mentions légales
      </h1>
      <p class="text-lg text-(--color-text-primary)/60">
        Cette page est en cours de rédaction. Pour toute question, contactez-nous à
        <a href="mailto:clean-ngo@outlook.com" class="underline">clean-ngo@outlook.com</a>.
      </p>
    </div>
  </Container>
</BaseLayout>
