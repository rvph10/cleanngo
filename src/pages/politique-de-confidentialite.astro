---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
---

<BaseLayout
  title="Politique de confidentialité"
  description="Politique de confidentialité de CleanNgo. Découvrez comment nous collectons, utilisons et protégeons vos données personnelles."
  noindex={true}
>
  <Container class="py-20">
    <div class="mx-auto max-w-2xl">
      <h1 class="font-display mb-8 text-4xl font-bold uppercase md:text-5xl">
        Politique de confidentialité
      </h1>
      <p class="text-lg text-(--color-text-primary)/60">
        Cette page est en cours de rédaction. Pour toute question relative à vos données personnelles,
        contactez-nous à <a href="mailto:clean-ngo@outlook.com" class="underline">clean-ngo@outlook.com</a>.
      </p>
    </div>
  </Container>
</BaseLayout>
