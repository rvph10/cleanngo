---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/ui/Container.astro";
import Hero from "@components/sections/Hero.astro";
import Services from "@components/sections/Services.astro";
import Features from "@components/sections/Features.astro";
import Testimonials from "@components/sections/Testimonials.astro";
import HowItWorks from "@components/sections/HowItWorks.astro";
import TeamCTA from "@components/sections/TeamCTA.astro";
import ServiceAreas from "@components/sections/ServiceAreas.astro";
import FAQ from "@components/sections/FAQ.astro";
import CTA from "@components/sections/CTA.astro";
import { imageAssets } from "@/data/images";
---

<BaseLayout
  title="Nettoyage de vitres, toitures et façades à Bruxelles"
  description="Lavage de vitres, démoussage toiture, nettoyage façades, gouttières et panneaux solaires à Bruxelles. Matériel professionnel. Devis gratuit."
>
  <!-- Preload the LCP video poster (hero, above the fold) -->
  <link slot="head" rel="preload" as="image" href={imageAssets.heroPoster} type="image/avif" />
  <Container>
    <Hero />
    <Services />
    <Features />
    <Testimonials />
    <HowItWorks />
    <TeamCTA />
    <ServiceAreas />
    <FAQ />
    <CTA />
  </Container>
</BaseLayout>
