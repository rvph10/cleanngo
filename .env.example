# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives booking form submissions (your inbox)
CONTACT_EMAIL=contact@cleanngo.be

# Publicly-accessible site URL (no trailing slash)
