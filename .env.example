# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives booking form submissions (your inbox)
CONTACT_EMAIL=contact@cleanngo.be

# "From" address shown in the email client.
# Must be from a domain you have verified in Resend.
# During testing you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=CleanNgo <noreply@cleanngo.be>

# Publicly-accessible site URL (no trailing slash)
PUBLIC_SITE_URL=https://cleanngo.be

# Umami analytics — only set this in production, leave unset on staging
PUBLIC_UMAMI_WEBSITE_ID=507071d5-d0ac-48bd-adb9-df4e1c04f5dd
